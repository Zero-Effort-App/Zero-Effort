/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# The service worker must always be re-checked so new deploys take over immediately.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed build assets are immutable and safe to cache for a year.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*
  Cache-Control: public, max-age=31536000

/*.html
  Cache-Control: no-cache, no-store, must-revalidate
