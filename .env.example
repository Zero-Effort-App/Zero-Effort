# ===== AGORA VIDEO CALL CONFIGURATION =====
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_certificate_here

# ===== WEB PUSH VAPID KEYS =====
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=admin@zeroeffort.com

# ===== SENDGRID EMAIL CONFIGURATION =====
SENDGRID_API_KEY=SG.your_key_here
SENDGRID_FROM_EMAIL=noreply@zeroeffort.com
SENDGRID_SENDER_NAME=ZERO EFFORT

# ===== EXISTING SUPABASE CONFIGURATION =====
SUPABASE_URL=your_existing_supabase_url
SUPABASE_ANON_KEY=your_existing_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_existing_service_role_key

# ===== NODE ENVIRONMENT =====
NODE_ENV=development
PORT=3001

# ===== FRONTEND URL =====
VITE_API_URL=http://localhost:3001/api
